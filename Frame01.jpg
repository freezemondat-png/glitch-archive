<div class="image-box">
    <img src="frame01.png" style=" .glitch-flicker {
    animation: flicker 2.8s infinite;
}

@keyframes flicker {
    0% { opacity:1; }
    48% { opacity:0.95; }
    50% { opacity:0.6; }
    52% { opacity:1; }
    80% { opacity:0.98; }
    100% { opacity:1; }
}
        width:100%;
        filter: contrast(1.3) brightness(0.8) grayscale(1);
        border:1px solid #2a2f36;
    ">
</div class="image-box glitch-flicker">
